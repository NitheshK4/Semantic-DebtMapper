# ==========================================
# Semantic Debt Mapper - Environment Config
# ==========================================

# --- Backend Settings ---
# A secure, random string used for API authentication
API_KEY=your_secure_api_key_here

# Database connection string (SQLite by default)
DATABASE_URL=sqlite:///./sdm.db

# --- Frontend Settings ---
# URL for the backend API
VITE_API_URL=http://localhost:8005/api/v1

# The frontend must pass this key to the backend
VITE_API_KEY=your_secure_api_key_here
